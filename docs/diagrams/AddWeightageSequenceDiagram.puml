@startuml AddWeightageSequenceDiagram

skinparam sequenceArrowThickness 2
skinparam roundcorner 5
skinparam maxmessagesize 60

Actor User as user
Participant "app:ModuleSync" as app
Participant "ui:Ui" as ui
Participant "parser:Parser" as parser
Participant "c:AddTodoCommand" as addCommand
Participant "mb:ModuleBook" as moduleBook
Participant "m:Module" as module
Participant "tl:TaskList" as taskList
Participant "t:Todo" as todo
Participant "s:Storage" as storage

note over app, parser
  Parser constructs the command via the standard
  Request Lifecycle (see Design chapter).
  Diagram begins at command dispatch.
end note

user -> app : add /mod CS2113 /task "Final Project" /w 25
activate app

app -> parser : parse(rawInput)
activate parser

note right of parser
  Extracts:
  moduleCode  = "CS2113"
  description = "Final Project"
  weightage   = 25 (or null if /w absent)
end note

create addCommand
parser -> addCommand : AddTodoCommand(...)
activate addCommand
deactivate addCommand

parser --> app : c:AddTodoCommand
deactivate parser

app -> addCommand : execute(mb, s, ui)
activate addCommand

addCommand -> moduleBook : getOrCreate(...)
activate moduleBook
moduleBook --> addCommand : m:Module
deactivate moduleBook

addCommand -> module : addTodo(...)
activate module

module -> taskList : addTodo(...)
activate taskList

create todo
taskList -> todo : Todo(...)
activate todo
deactivate todo

taskList -> todo : setWeightage(...)
activate todo
todo --> taskList
deactivate todo

taskList --> module : t:Todo
deactivate taskList

module --> addCommand : t:Todo
deactivate module

addCommand -> storage : save(mb)
activate storage
storage --> addCommand
deactivate storage

addCommand -> ui : showTaskAdded(m, t, totalCount)
activate ui
ui --> addCommand
deactivate ui

addCommand --> app
deactivate addCommand

app --> user : confirmation with weightage
deactivate app

@enduml
