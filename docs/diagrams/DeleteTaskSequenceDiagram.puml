@startuml DeleteTaskSequenceDiagram

skinparam sequenceArrowThickness 2
skinparam roundcorner 5
skinparam maxmessagesize 60
skinparam sequenceParticipant underline

Actor User as user
Participant "ModuleSync" as app
Participant "Ui" as ui
Participant "Parser" as parser
Participant "DeleteCommand" as cmd
Participant "ModuleBook" as moduleBook
Participant "Storage" as storage
Participant "Task" as task

user -> app : enter "delete 3"
activate app

app -> ui : readCommand()
activate ui
ui --> app : rawInput
deactivate ui

app -> parser : parse(rawInput)
activate parser

note right of parser
  Parses display index = 3
  (1-based, global across modules)
end note

create cmd
parser -> cmd : new DeleteCommand(3)
parser --> app : cmd
deactivate parser

app -> cmd : execute(moduleBook, storage, ui)
activate cmd

cmd -> moduleBook : removeTaskByDisplayIndex(3)
activate moduleBook
moduleBook --> cmd : task
deactivate moduleBook

cmd -> storage : save(moduleBook)
activate storage
storage --> cmd
deactivate storage

cmd -> ui : showTaskDeleted(task, totalTasks)
activate ui
ui --> user : prints deleted task + new count
deactivate ui

cmd --> app
deactivate cmd

deactivate app

@enduml
