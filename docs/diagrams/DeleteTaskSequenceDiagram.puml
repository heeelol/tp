@startuml DeleteTaskSequenceDiagram

skinparam sequenceArrowThickness 2
skinparam roundcorner 5
skinparam maxmessagesize 60

Actor User as user
Participant "app:ModuleSync" as app
Participant "parser:Parser" as parser
Participant "cmd:DeleteCommand" as cmd
Participant "mb:ModuleBook" as moduleBook
Participant "s:Storage" as storage
Participant "ui:Ui" as ui

note over app, parser
  Request Lifecycle (parse → dispatch) is
  described in the Design chapter.
  Diagram begins at command dispatch.
end note

user -> app : delete 3
activate app

app -> parser : parse(rawInput)
activate parser

note right of parser
  Parses display index = 3
  (1-based, global across modules)
end note

create cmd
parser -> cmd : DeleteCommand(3)
activate cmd
deactivate cmd

parser --> app : cmd:DeleteCommand
deactivate parser

app -> cmd : execute(mb, s, ui)
activate cmd

cmd -> moduleBook : removeTaskByDisplayIndex(3)
activate moduleBook
moduleBook --> cmd : t:Task
deactivate moduleBook

cmd -> storage : save(mb)
activate storage
storage --> cmd
deactivate storage

cmd -> ui : showTaskDeleted(t, totalTasks)
activate ui
ui --> cmd
deactivate ui

cmd --> app
deactivate cmd

app --> user : deleted task confirmation
deactivate app

@enduml
