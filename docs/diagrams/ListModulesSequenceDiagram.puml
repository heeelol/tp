@startuml ListModulesSequenceDiagram

skinparam sequenceArrowThickness 2
skinparam roundcorner 5
skinparam maxmessagesize 60
skinparam sequenceParticipant underline

Actor User as user
Participant "ModuleSync" as app
Participant "Ui" as ui
Participant "Parser" as parser
Participant "ListModulesCommand" as cmd
Participant "ModuleBook" as moduleBook
Participant "Module" as module
Participant "TaskList" as taskList

user -> app : enter "modules"
activate app

app -> ui : readCommand()
activate ui
ui --> app : rawInput
deactivate ui

app -> parser : parse(rawInput)
activate parser

note right of parser
  Recognises: modules
end note

create cmd
parser -> cmd : new ListModulesCommand()
parser --> app : cmd
deactivate parser

app -> cmd : execute(moduleBook, storage, ui)
activate cmd

cmd -> ui : showModuleList(moduleBook)
activate ui
ui -> moduleBook : getModules()
activate moduleBook
moduleBook --> ui : modules
deactivate moduleBook

loop for each module
  ui -> module : getCode()
  module --> ui : code
  ui -> module : getTasks()
  module --> ui : taskList
  ui -> taskList : size()
  taskList --> ui : taskCount
end

ui --> user : prints module list + task counts
deactivate ui

cmd --> app
deactivate cmd

deactivate app

@enduml
