@startuml ListModulesSequenceDiagram

skinparam sequenceArrowThickness 2
skinparam roundcorner 5
skinparam maxmessagesize 60

Actor User as user
Participant "app:ModuleSync" as app
Participant "parser:Parser" as parser
Participant "cmd:ListModulesCommand" as cmd
Participant "ui:Ui" as ui
Participant "mb:ModuleBook" as moduleBook
Participant "m:Module" as module
Participant "tl:TaskList" as taskList

note over app, parser
  Request Lifecycle (parse → dispatch) is
  described in the Design chapter.
  Diagram begins at command dispatch.
end note

user -> app : module list
activate app

app -> parser : parse(rawInput)
activate parser

create cmd
parser -> cmd : ListModulesCommand()
activate cmd
deactivate cmd

parser --> app : cmd:ListModulesCommand
deactivate parser

app -> cmd : execute(mb, s, ui)
activate cmd

cmd -> ui : showModuleList(mb)
activate ui

ui -> moduleBook : getModules()
activate moduleBook
moduleBook --> ui : modules:Collection<Module>
deactivate moduleBook

loop for each module
  ui -> module : getCode()
  activate module
  module --> ui : code:String
  deactivate module

  ui -> module : getTasks()
  activate module
  module --> ui : tl:TaskList
  deactivate module

  ui -> taskList : size()
  activate taskList
  taskList --> ui : taskCount:int
  deactivate taskList
end

ui --> cmd
deactivate ui

cmd --> app
deactivate cmd

app --> user : module list with task counts
deactivate app

@enduml
