@startuml ListNotDoneSequenceDiagram

skinparam sequenceArrowThickness 2
skinparam roundcorner 5
skinparam maxmessagesize 60

Actor User as user
Participant "app:ModuleSync" as app
Participant "parser:Parser" as parser
Participant "cmd:ListNotDoneCommand" as cmd
Participant "ui:Ui" as ui
Participant "mb:ModuleBook" as moduleBook
Participant "t:Task" as task

note over app, parser
  Request Lifecycle (parse → dispatch) is
  described in the Design chapter.
  Diagram begins at command dispatch.
end note

user -> app : list /notdone /mod CS2113
activate app

app -> parser : parse(rawInput)
activate parser

note right of parser
  Detects: list command
  Filter: /notdone + /mod CS2113
end note

create cmd
parser -> cmd : ListNotDoneCommand("CS2113")
activate cmd
deactivate cmd

parser --> app : cmd:ListNotDoneCommand
deactivate parser

app -> cmd : execute(mb, s, ui)
activate cmd

cmd -> ui : showNotDoneTaskList(mb, "CS2113")
activate ui

ui -> moduleBook : getModules()
activate moduleBook
moduleBook --> ui : modules:Collection<Module>
deactivate moduleBook

loop for each task across all modules
  ui -> task : isDone()
  activate task
  task --> ui : done:boolean
  deactivate task
end

ui --> cmd
deactivate ui

cmd --> app
deactivate cmd

app --> user : not-done tasks (global indices preserved)
deactivate app

@enduml
