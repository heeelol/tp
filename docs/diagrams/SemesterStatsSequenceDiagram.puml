@startuml SemesterStatsSequenceDiagram

skinparam sequenceArrowThickness 2
skinparam roundcorner 5
skinparam maxmessagesize 60

Actor User as user
Participant "app:ModuleSync" as app
Participant "parser:Parser" as parser
Participant "cmd:SemesterStatsCommand" as cmd
Participant "ui:Ui" as ui
Participant "mb:ModuleBook" as moduleBook
Participant "m:Module" as module
Participant "tl:TaskList" as taskList
Participant "t:Task" as task

note over app, parser
  Request Lifecycle (parse → dispatch) is
  described in the Design chapter.
  Diagram begins at command dispatch.
end note

user -> app : semester stats
activate app

app -> parser : parse(rawInput)
activate parser

create cmd
parser -> cmd : SemesterStatsCommand(...)
activate cmd
deactivate cmd

parser --> app : cmd:SemesterStatsCommand
deactivate parser

app -> cmd : execute(mb, s, ui)
activate cmd

cmd -> ui : showSemesterStatistics(mb)
activate ui

ui -> moduleBook : getModules()
activate moduleBook
moduleBook --> ui : modules:Collection<Module>
deactivate moduleBook

loop for each module
  ui -> module : getTasks()
  activate module
  module --> ui : tl:TaskList
  deactivate module

  ui -> taskList : asUnmodifiableList()
  activate taskList
  taskList --> ui : tasks:List<Task>
  deactivate taskList

  loop for each task
    ui -> task : isDone()
    activate task
    task --> ui : done:boolean
    deactivate task

    ui -> task : getWeightage()
    activate task
    task --> ui : weightage:Integer
    deactivate task
  end
end

ui --> cmd
deactivate ui

cmd --> app
deactivate cmd

app --> user : semester summary + per-module distribution
deactivate app

@enduml
