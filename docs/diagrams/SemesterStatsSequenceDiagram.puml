@startuml SemesterStatsSequenceDiagram

skinparam sequenceArrowThickness 2
skinparam roundcorner 5
skinparam maxmessagesize 60
skinparam sequenceParticipant underline

Actor User as user
Participant "ModuleSync" as app
Participant "Ui" as ui
Participant "Parser" as parser
Participant "SemesterStatsCommand" as cmd
Participant "ModuleBook" as moduleBook
Participant "Module" as module
Participant "TaskList" as taskList
Participant "Task" as task

user -> app : enter "semesterstats"
activate app

app -> ui : readCommand()
activate ui
ui --> app : rawInput
deactivate ui

app -> parser : parse(rawInput)
activate parser

note right of parser
  Recognises: semesterstats
end note

create cmd
parser -> cmd : new SemesterStatsCommand()
parser --> app : cmd
deactivate parser

app -> cmd : execute(moduleBook, storage, ui)
activate cmd

cmd -> ui : showSemesterStatistics(moduleBook)
activate ui

ui -> moduleBook : getModules()
activate moduleBook
moduleBook --> ui : modules
deactivate moduleBook

loop for each module
  ui -> module : getTasks()
  module --> ui : taskList
  ui -> taskList : asUnmodifiableList()
  taskList --> ui : tasks

  loop for each task
    ui -> task : isDone()
    task --> ui : boolean
    ui -> task : hasWeightage()
    task --> ui : boolean
    alt has weightage
      ui -> task : getWeightage()
      task --> ui : int
    end
  end
end

ui --> user : prints semester summary + per-module distribution
deactivate ui

cmd --> app
deactivate cmd

deactivate app

@enduml
